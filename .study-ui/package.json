{
  "name": "study-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:shell": "node --test --experimental-strip-types src/lib/app-shell.test.ts",
    "test": "vitest run",
    "test:source": "node --test --experimental-strip-types \"src/**/*.source.test.ts\"",
    "sync:tauri-macos-config": "node --experimental-strip-types scripts/sync-tauri-macos-config.ts",
    "tauri": "tauri",
    "tauri:dev": "npm run sync:tauri-macos-config && tauri dev",
    "tauri:build": "npm run sync:tauri-macos-config && tauri build",
    "test:theme": "node --test src/lib/theme.test.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "2.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "overlayscrollbars": "2.16.0",
    "overlayscrollbars-react": "0.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "2.7.0",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "24.1.3",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "3.2.4"
  }
